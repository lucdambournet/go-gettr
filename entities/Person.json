{
  "name": "Person",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the person"
    },
    "avatar_color": {
      "type": "string",
      "description": "Color identifier for avatar"
    },
    "weekly_allowance": {
      "type": "number",
      "default": 0,
      "description": "Weekly allowance (children only)"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Whether this person is active"
    },
    "is_parent": {
      "type": "boolean",
      "default": false,
      "description": "Whether this person is a parent/guardian"
    },
    "notify_on_payout_request": {
      "type": "boolean",
      "default": true,
      "description": "Parent: receive notification on payout requests"
    },
    "max_single_payout": {
      "type": "number",
      "description": "Parent: maximum amount allowed per payout"
    }
  },
  "required": [
    "name"
  ]
}