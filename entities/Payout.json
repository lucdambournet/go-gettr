{
  "name": "Payout",
  "type": "object",
  "properties": {
    "person_id": {
      "type": "string",
      "description": "ID of the person requesting payout"
    },
    "amount": {
      "type": "number",
      "description": "Amount to cash out"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "paid"
      ],
      "default": "pending",
      "description": "Status of the payout request"
    },
    "requested_date": {
      "type": "string",
      "format": "date",
      "description": "Date the payout was requested"
    },
    "paid_date": {
      "type": "string",
      "format": "date",
      "description": "Date the payout was marked as paid"
    },
    "note": {
      "type": "string",
      "description": "Optional note from parent"
    }
  },
  "required": [
    "person_id",
    "amount"
  ]
}