{
  "name": "ChoreLog",
  "type": "object",
  "properties": {
    "chore_id": {
      "type": "string",
      "description": "ID of the chore"
    },
    "person_id": {
      "type": "string",
      "description": "ID of the person who completed it"
    },
    "week_start": {
      "type": "string",
      "format": "date",
      "description": "Start of the week (Monday)"
    },
    "day": {
      "type": "string",
      "format": "date",
      "description": "Specific day the chore was completed"
    },
    "completed": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "chore_id",
    "person_id",
    "week_start",
    "day"
  ]
}